{
  "name": "clawagents",
  "version": "6.6.4",
  "description": "Backend agent engine combining openclaw resilience with deepagents reasoning",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./acp": {
      "types": "./dist/acp/index.d.ts",
      "import": "./dist/acp/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js"
    },
    "./cron": {
      "types": "./dist/cron/index.d.ts",
      "import": "./dist/cron/index.js"
    },
    "./eval": {
      "types": "./dist/eval.d.ts",
      "import": "./dist/eval.js"
    },
    "./media": {
      "types": "./dist/media/index.d.ts",
      "import": "./dist/media/index.js"
    },
    "./media/*": {
      "types": "./dist/media/*.d.ts",
      "import": "./dist/media/*.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    },
    "./permissions": {
      "types": "./dist/permissions/index.d.ts",
      "import": "./dist/permissions/index.js"
    },
    "./permissions/*": {
      "types": "./dist/permissions/*.d.ts",
      "import": "./dist/permissions/*.js"
    },
    "./rl": {
      "types": "./dist/rl/index.d.ts",
      "import": "./dist/rl/index.js"
    },
    "./sandbox": {
      "types": "./dist/sandbox/index.d.ts",
      "import": "./dist/sandbox/index.js"
    },
    "./sandbox/*": {
      "types": "./dist/sandbox/*.d.ts",
      "import": "./dist/sandbox/*.js"
    },
    "./settings": {
      "types": "./dist/settings/index.d.ts",
      "import": "./dist/settings/index.js"
    },
    "./settings/*": {
      "types": "./dist/settings/*.d.ts",
      "import": "./dist/settings/*.js"
    },
    "./testing/*": {
      "types": "./dist/testing/*.d.ts",
      "import": "./dist/testing/*.js"
    },
    "./tools/*": {
      "types": "./dist/tools/*.d.ts",
      "import": "./dist/tools/*.js"
    },
    "./tracing": {
      "types": "./dist/tracing/index.d.ts",
      "import": "./dist/tracing/index.js"
    },
    "./tracing/*": {
      "types": "./dist/tracing/*.d.ts",
      "import": "./dist/tracing/*.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "clawagents": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "npx tsx src/cli.ts",
    "dev": "npx tsx --watch src/cli.ts",
    "task": "npx tsx src/cli.ts --task",
    "build": "tsc -p tsconfig.build.json && node scripts/postbuild.mjs",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/corner_cases.test.ts src/tools_comprehensive.test.ts src/interface.test.ts src/gemini_thought_signature.test.ts src/malformed_fn_call.test.ts src/session-preload.test.ts src/tooling-next.test.ts src/infra-improvements.test.ts src/redact.test.ts src/commands.test.ts src/steer.test.ts src/paths.test.ts src/aux-models.test.ts src/transport.test.ts src/memory/compaction.test.ts src/background.test.ts src/tools/registry.test.ts src/tools/registry.integration.test.ts src/tools/subagent.test.ts src/tools/web.test.ts src/tools/ask-user-question.test.ts src/tools/exec-safety-v2.test.ts src/media/images.test.ts src/settings/resolver.test.ts src/testing/mock-provider.test.ts src/tracing/tracing.test.ts src/mcp/mcp.test.ts src/mcp/env-scrub.test.ts src/sandbox/credential-proxy.test.ts src/gateway/gateway.test.ts src/handoffs.test.ts src/browser/browser.test.ts src/cron/cron.test.ts src/acp/acp.test.ts src/rl/rl.test.ts tests/simulated.test.ts",
    "test:hermetic": "bash scripts/run_tests.sh",
    "test:surfaces": "tsx tests/openai_agents_surfaces.test.ts",
    "test:all": "npm run test && npm run test:surfaces",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "agent",
    "llm",
    "openclaw",
    "deepagents"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/x1jiang/clawagents.git"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "js-tiktoken": "^1.0.21",
    "openai": "^5.8.2"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "@google/genai": "^1.9.0",
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "@zed-industries/agent-client-protocol": ">=0.1.0",
    "cron-parser": ">=4.0.0",
    "playwright": ">=1.40.0",
    "sharp": "^0.33.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
