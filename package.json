{
  "name": "clawagents",
  "version": "6.2.2",
  "description": "Backend agent engine combining openclaw resilience with deepagents reasoning",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "clawagents": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "npx tsx src/cli.ts",
    "dev": "npx tsx --watch src/cli.ts",
    "task": "npx tsx src/cli.ts --task",
    "build": "tsc -p tsconfig.build.json && node scripts/postbuild.mjs",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/corner_cases.test.ts src/tools_comprehensive.test.ts src/interface.test.ts src/gemini_thought_signature.test.ts src/malformed_fn_call.test.ts src/tools/registry.test.ts src/tools/registry.integration.test.ts src/tools/web.test.ts tests/simulated.test.ts",
    "test:surfaces": "tsx tests/openai_agents_surfaces.test.ts",
    "test:all": "npm run test && npm run test:surfaces",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "agent",
    "llm",
    "openclaw",
    "deepagents"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/x1jiang/clawagents.git"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "js-tiktoken": "^1.0.21",
    "openai": "^5.8.2"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "@google/genai": "^1.9.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
